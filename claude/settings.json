{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(semgrep:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(xargs:*)",
      "Bash(mkdir:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git checkout:*)",
      "Bash(git worktree:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git rev-parse:*)",
      "Bash(git status:*)",
      "Bash(git pull:*)",
      "Bash(cd:*)",
      "Bash(gh pr view:*)",
      "Bash(go doc:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(go generate:*)",
      "Bash(gh pr create --draft:*)",
      "Bash(git push:*)",
      "Read(~/.claude/**)",
      "Glob(~/.claude/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  }
}
